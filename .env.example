# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For local dev: postgresql://postgres:password@localhost:5432/rental_db
# For Neon/Railway: copy the connection string from your dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rental_db?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
# URL of your deployed app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for JWT signing — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Event Rental Manager"

# ─── Future: File Storage (Vercel Blob) ───────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=""

# ─── Future: Email (Resend / SendGrid) ────────────────────────────────────────
# RESEND_API_KEY=""
# FROM_EMAIL="noreply@yourcompany.com"

# ─── Future: Payments (Stripe) ────────────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""
