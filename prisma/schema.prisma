generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectsCreated   Project[]        @relation("ProjectCreatedBy")
  invoicesCreated   Invoice[]        @relation("InvoiceCreatedBy")
  maintenanceLogged MaintenanceLog[] @relation("MaintenanceLoggedBy")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id          String   @id @default(cuid())
  refCode     String   @unique
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  taxId       String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
  invoices Invoice[]
}

// ============================================================
// WAREHOUSES
// ============================================================

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serializedUnits SerializedUnit[]
  inventoryStocks InventoryItemWarehouseStock[]

  @@index([isActive])
}

// ============================================================
// INVENTORY
// ============================================================

model InventoryCategory {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  description   String?
  color         String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  subCategories InventorySubCategory[]
  items         InventoryItem[]
}

model InventorySubCategory {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  slug       String
  createdAt  DateTime @default(now())

  category InventoryCategory @relation(fields: [categoryId], references: [id])
  items    InventoryItem[]

  @@unique([categoryId, slug])
}

model InventoryItem {
  id             String       @id @default(cuid())
  refCode        String       @unique
  name           String
  description    String?
  categoryId     String
  subCategoryId  String?
  trackingMode   TrackingMode @default(BULK)
  totalQuantity  Int          @default(0)

  // Default rental rates (overridable per project line item)
  dailyRateAmount   Int?
  dailyRateCurrency String   @default("USD")

  // Asset value
  replacementCostAmount   Int?
  replacementCostCurrency String @default("USD")

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category       InventoryCategory     @relation(fields: [categoryId], references: [id])
  subCategory    InventorySubCategory? @relation(fields: [subCategoryId], references: [id])
  serializedUnits  SerializedUnit[]
  projectLineItems ProjectEquipmentItem[]
  maintenanceLogs  MaintenanceLog[]
  subRentalItems   SubRentalItem[]
  warehouseStocks  InventoryItemWarehouseStock[]
  images           InventoryItemImage[]
  properties       InventoryItemProperty[]

  @@index([categoryId])
  @@index([trackingMode])
  @@index([isActive])
}

model InventoryItemImage {
  id              String        @id @default(cuid())
  inventoryItemId String
  url             String
  caption         String?
  sortOrder       Int           @default(0)
  isPrimary       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
}

model InventoryPropertyDef {
  id        String            @id @default(cuid())
  name      String            @unique
  slug      String            @unique
  valueType PropertyValueType
  unit      String?
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  values InventoryItemProperty[]

  @@index([valueType])
}

model InventoryItemProperty {
  id              String               @id @default(cuid())
  inventoryItemId String
  propertyDefId   String
  textValue       String?
  numericValue    Decimal?             @db.Decimal(15, 4)
  booleanValue    Boolean?

  inventoryItem InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  propertyDef   InventoryPropertyDef @relation(fields: [propertyDefId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, propertyDefId])
  @@index([inventoryItemId])
  @@index([propertyDefId])
}

model InventoryItemWarehouseStock {
  id              String        @id @default(cuid())
  inventoryItemId String
  warehouseId     String
  quantity        Int           @default(0)

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([inventoryItemId, warehouseId])
  @@index([inventoryItemId])
  @@index([warehouseId])
}

enum TrackingMode {
  SERIALIZED
  BULK
}

enum PropertyValueType {
  TEXT
  NUMERIC
  BOOLEAN
}

model SerializedUnit {
  id              String     @id @default(cuid())
  inventoryItemId String
  serialNumber    String
  assetTag        String?
  status          UnitStatus @default(AVAILABLE)
  purchaseDate    DateTime?
  purchasePriceAmount   Int?
  purchasePriceCurrency String @default("USD")
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  warehouseId   String?
  warehouse     Warehouse?                   @relation(fields: [warehouseId], references: [id])

  inventoryItem InventoryItem                @relation(fields: [inventoryItemId], references: [id])
  maintenanceLogs MaintenanceLog[]
  allocations   ProjectEquipmentAllocation[]

  @@unique([inventoryItemId, serialNumber])
  @@index([status])
  @@index([warehouseId])
}

enum UnitStatus {
  AVAILABLE
  IN_SERVICE
  IN_REPAIR
  RETIRED
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id           String        @id @default(cuid())
  refCode      String        @unique
  name         String
  type         ProjectType
  status       ProjectStatus @default(INQUIRY)
  clientId     String
  venue        String?
  city         String?
  country      String?
  loadInAt     DateTime?
  startAt      DateTime
  endAt        DateTime
  loadOutAt    DateTime?
  currencyCode String        @default("USD")
  taxRate      Decimal?      @db.Decimal(5, 4)
  depositAmount Int?
  notes        String?
  internalNotes String?
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client            Client                 @relation(fields: [clientId], references: [id])
  createdBy         User                   @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  equipmentItems    ProjectEquipmentItem[]
  crewAssignments   CrewAssignment[]
  subRentals        SubRental[]
  invoices          Invoice[]
  expenses          ProjectExpense[]
  timesheets        Timesheet[]
  phases            ProjectPhase[]
  laborSubcontracts LaborSubcontract[]

  @@index([status])
  @@index([clientId])
  @@index([startAt, endAt])
}

enum ProjectType {
  SINGLE_EVENT
  MULTI_DAY_TOUR
  LONG_TERM_RENTAL
}

enum ProjectStatus {
  INQUIRY
  QUOTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProjectEquipmentItem {
  id              String   @id @default(cuid())
  projectId       String
  inventoryItemId String
  quantityNeeded  Int      @default(1)
  unitRateAmount  Int?
  unitRateCurrency String?
  rateType        RateType @default(DAILY)
  rateDays        Int      @default(1)
  description     String?
  notes           String?
  sortOrder       Int      @default(0)

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  allocations   ProjectEquipmentAllocation[]

  @@index([projectId])
}

enum RateType {
  DAILY
  WEEKLY
  FLAT
}

model ProjectEquipmentAllocation {
  id                    String @id @default(cuid())
  projectEquipmentItemId String
  serializedUnitId      String

  projectEquipmentItem ProjectEquipmentItem @relation(fields: [projectEquipmentItemId], references: [id], onDelete: Cascade)
  serializedUnit       SerializedUnit       @relation(fields: [serializedUnitId], references: [id])

  @@unique([projectEquipmentItemId, serializedUnitId])
  @@index([serializedUnitId])
}

model ProjectExpense {
  id          String          @id @default(cuid())
  projectId   String
  description String
  category    ExpenseCategory
  amount      Int
  currency    String          @default("USD")
  receiptUrl  String?
  date        DateTime
  notes       String?
  createdAt   DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ExpenseCategory {
  FUEL
  ACCOMMODATION
  CATERING
  TRANSPORT
  SUPPLIES
  EQUIPMENT_REPAIR
  OTHER
}

// ============================================================
// SUB-RENTALS
// ============================================================

model SubRental {
  id            String          @id @default(cuid())
  projectId     String
  vendorName    String
  vendorContact String?
  vendorEmail   String?
  status        SubRentalStatus @default(REQUESTED)
  startAt       DateTime
  endAt         DateTime
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   SubRentalItem[]

  @@index([projectId])
}

enum SubRentalStatus {
  REQUESTED
  CONFIRMED
  RECEIVED
  RETURNED
  CANCELLED
}

model SubRentalItem {
  id              String   @id @default(cuid())
  subRentalId     String
  inventoryItemId String?
  description     String
  quantity        Int      @default(1)
  unitRateAmount  Int
  unitRateCurrency String  @default("USD")
  rateType        RateType @default(DAILY)
  rateDays        Int      @default(1)

  subRental     SubRental      @relation(fields: [subRentalId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
}

// ============================================================
// PROJECT PHASES & LABOR SUBCONTRACTS
// ============================================================

enum PhaseType {
  PACKING
  LOAD_IN
  SETUP
  SHOW
  STRIKE
  LOAD_OUT
  TRAVEL
  CUSTOM
}

model ProjectPhase {
  id          String    @id @default(cuid())
  projectId   String
  name        PhaseType
  customLabel String?
  startAt     DateTime
  endAt       DateTime
  sortOrder   Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crewAssignments   CrewAssignment[]
  laborSubcontracts LaborSubcontract[]

  @@index([projectId])
}

enum LaborSubcontractStatus {
  REQUESTED
  CONFIRMED
  RECEIVED
  COMPLETED
  CANCELLED
}

model LaborSubcontract {
  id                String                 @id @default(cuid())
  projectId         String
  phaseId           String?
  vendorName        String
  vendorContact     String?
  vendorEmail       String?
  role              String?
  quantity          Int                    @default(1)
  startAt           DateTime
  endAt             DateTime
  dailyRateAmount   Int?
  dailyRateCurrency String                 @default("USD")
  status            LaborSubcontractStatus @default(REQUESTED)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phaseId])
}

// ============================================================
// CREW
// ============================================================

model CrewMember {
  id               String    @id @default(cuid())
  refCode          String    @unique
  firstName        String
  lastName         String
  email            String?   @unique
  phone            String?
  type             CrewType  @default(FREELANCER)
  role             String?
  isActive         Boolean   @default(true)
  taxId            String?
  emergencyContact String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rates       CrewRate[]
  assignments CrewAssignment[]
  timesheets  Timesheet[]
  expenses    CrewExpense[]
}

enum CrewType {
  EMPLOYEE
  FREELANCER
}

model CrewRate {
  id            String       @id @default(cuid())
  crewMemberId  String
  rateType      CrewRateType
  amount        Int
  currency      String       @default("USD")
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?

  crewMember CrewMember @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)

  @@index([crewMemberId])
}

enum CrewRateType {
  REGULAR
  OVERTIME
  DOUBLE_TIME
  TRAVEL_DAY
  PER_DIEM
}

model CrewAssignment {
  id           String   @id @default(cuid())
  projectId    String
  crewMemberId String
  phaseId      String?
  role         String?
  startAt      DateTime
  endAt        DateTime
  notes        String?
  createdAt    DateTime @default(now())

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crewMember CrewMember    @relation(fields: [crewMemberId], references: [id])
  phase      ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  timesheets Timesheet[]

  @@index([projectId])
  @@index([crewMemberId])
  @@index([phaseId])
}

// ============================================================
// TIME TRACKING
// ============================================================

model Timesheet {
  id               String          @id @default(cuid())
  projectId        String
  crewAssignmentId String?
  crewMemberId     String
  clockIn          DateTime
  clockOut         DateTime?
  breakMinutes     Int             @default(0)
  timeType         TimesheetType   @default(WORK)

  // Calculated on approval
  regularHours    Decimal? @db.Decimal(6, 2)
  overtimeHours   Decimal? @db.Decimal(6, 2)
  doubleTimeHours Decimal? @db.Decimal(6, 2)

  // Rate snapshot (locked at approval time)
  regularRateAmount    Int?
  overtimeRateAmount   Int?
  doubleTimeRateAmount Int?
  currency             String @default("USD")

  totalAmount Int?

  status      TimesheetStatus @default(DRAFT)
  notes       String?
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project        Project         @relation(fields: [projectId], references: [id])
  crewAssignment CrewAssignment? @relation(fields: [crewAssignmentId], references: [id])
  crewMember     CrewMember      @relation(fields: [crewMemberId], references: [id])

  @@index([projectId])
  @@index([crewMemberId])
  @@index([status])
}

enum TimesheetType {
  WORK
  TRAVEL
  PER_DIEM
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model CrewExpense {
  id           String        @id @default(cuid())
  crewMemberId String
  projectId    String?
  description  String
  amount       Int
  currency     String        @default("USD")
  receiptUrl   String?
  date         DateTime
  status       ExpenseStatus @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  crewMember CrewMember @relation(fields: [crewMemberId], references: [id])

  @@index([crewMemberId])
  @@index([status])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REIMBURSED
  REJECTED
}

// ============================================================
// MAINTENANCE
// ============================================================

model MaintenanceLog {
  id              String            @id @default(cuid())
  inventoryItemId String
  serializedUnitId String?
  type            MaintenanceType
  description     String
  status          MaintenanceStatus @default(OPEN)
  reportedAt      DateTime          @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  vendor          String?
  technicianName  String?
  costAmount      Int?
  costCurrency    String            @default("USD")
  loggedById      String
  notes           String?
  updatedAt       DateTime          @updatedAt

  inventoryItem  InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  serializedUnit SerializedUnit? @relation(fields: [serializedUnitId], references: [id])
  loggedBy       User            @relation("MaintenanceLoggedBy", fields: [loggedById], references: [id])

  @@index([inventoryItemId])
  @@index([status])
}

enum MaintenanceType {
  SCHEDULED_SERVICE
  REPAIR
  INSPECTION
  CLEANING
  CALIBRATION
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================================
// INVOICING
// ============================================================

model Invoice {
  id             String        @id @default(cuid())
  refCode        String        @unique
  projectId      String
  clientId       String
  status         InvoiceStatus @default(DRAFT)
  type           InvoiceType   @default(STANDARD)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  currencyCode   String        @default("USD")
  subtotalAmount Int
  taxAmount      Int           @default(0)
  discountAmount Int           @default(0)
  totalAmount    Int
  paidAmount     Int           @default(0)
  notes          String?
  terms          String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project   Project          @relation(fields: [projectId], references: [id])
  client    Client           @relation(fields: [clientId], references: [id])
  createdBy User             @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lineItems InvoiceLineItem[]
  payments  InvoicePayment[]

  @@index([status])
  @@index([clientId])
  @@index([projectId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum InvoiceType {
  STANDARD
  DEPOSIT
  FINAL
  CREDIT_NOTE
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitAmount  Int
  totalAmount Int
  taxRate     Decimal? @db.Decimal(5, 4)
  sortOrder   Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoicePayment {
  id          String        @id @default(cuid())
  invoiceId   String
  amount      Int
  currency    String
  method      PaymentMethod @default(BANK_TRANSFER)
  receivedAt  DateTime
  reference   String?
  notes       String?
  createdAt   DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum PaymentMethod {
  BANK_TRANSFER
  CHECK
  CASH
  CARD
  OTHER
}

// ============================================================
// SETTINGS / MULTI-CURRENCY
// ============================================================

model CurrencyConfig {
  code           String   @id
  name           String
  symbol         String
  isBaseCurrency Boolean  @default(false)
  isActive       Boolean  @default(true)
  exchangeRate   Decimal  @db.Decimal(12, 6)
  updatedAt      DateTime @updatedAt
}

model SystemSettings {
  id                  String   @id @default("singleton")
  companyName         String
  companyAddress      String?
  companyEmail        String?
  companyPhone        String?
  companyLogoUrl      String?
  defaultCurrencyCode String   @default("USD")
  defaultTaxRate      Decimal? @db.Decimal(5, 4)
  invoiceTermsDays    Int      @default(30)
  invoiceNotes        String?
  otDailyThreshold    Int      @default(8)
  otWeeklyThreshold   Int      @default(40)
  updatedAt           DateTime @updatedAt
}
